# =============================================================================
# MikroTik Billing Platform — Dokploy Deployment Configuration
# =============================================================================
# Copy this file to .env and fill in your values before running:
#   docker compose -f dokploy-compose.yml up -d
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=mikrotik_config_builder
DB_USER=postgres
DB_PASSWORD=change-this-to-a-strong-password

# ─── Security (REQUIRED — change these immediately!) ──────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-64-char-hex-string
# Must be exactly 32 characters
ENCRYPTION_KEY=change-this-to-exactly-32-chars!

# ─── Admin Account (auto-created on first startup) ────────────────────────────
INITIAL_ADMIN_EMAIL=admin@yourisp.com
INITIAL_ADMIN_PASSWORD=change-this-admin-password

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Set to your frontend domain.
# If empty, defaults to the request origin (less secure, but works for single domain).
CORS_ORIGIN=https://billing.yourisp.com

# ─── App URL (used in provisioning scripts as callback base URL) ──────────────
PUBLIC_APP_URL=https://billing.yourisp.com

# ─── Payment Integrations (optional — leave blank to disable) ─────────────────
# M-Pesa (Kenya)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_ENVIRONMENT=live

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=

# ─── SMS / Messaging (optional — leave blank to disable) ─────────────────────
# Africa's Talking
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=MyISP

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── WhatsApp (optional — leave blank to disable) ────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ─── Email (optional — leave blank to disable) ───────────────────────────────
# AWS SES
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ─── Monitoring & Error Tracking (optional) ───────────────────────────────────
SENTRY_DSN=
ENABLE_MONITORING_API=false

# ─── Network Features ─────────────────────────────────────────────────────────
ENABLE_ROUTER_CONNECTIVITY=false

# MikroTik Config Builder - Production Environment Variables
# Copy this file to .env and update the values

# ==========================================
# Database Configuration
# ==========================================
# Generate a strong password: openssl rand -hex 32
DB_PASSWORD=your_secure_database_password_here

# ==========================================
# Security Keys (IMPORTANT: Change these!)
# ==========================================
# Generate JWT Secret: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_key_change_this_to_random_64_chars

# Generate Encryption Key: openssl rand -hex 32
ENCRYPTION_KEY=your_encryption_key_change_this_to_32_chars

# Initial production admin (required on first production boot if users table is empty)
INITIAL_ADMIN_EMAIL=admin@your-domain.com
INITIAL_ADMIN_PASSWORD=change_this_initial_admin_password

# ==========================================
# Optional Integrations
# ==========================================
# Leave blank if not using

# Africa's Talking SMS
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=MyISP

# M-Pesa Payment
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_ENVIRONMENT=live

# WhatsApp Notifications
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ==========================================
# Docker Deployment
# ==========================================
# For VPS deployment, access your app at:
# http://your-server-ip

# For Dokploy, set CORS_ORIGIN to your domain:
# CORS_ORIGIN=https://your-domain.com
